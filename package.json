{
  "name": "@calltelemetry/openclaw-linear",
  "version": "0.9.25",
  "description": "Linear Agent plugin for OpenClaw — webhook-driven AI pipeline with OAuth, multi-agent routing, and issue triage",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/calltelemetry/openclaw-linear-plugin.git"
  },
  "homepage": "https://github.com/calltelemetry/openclaw-linear-plugin#readme",
  "keywords": [
    "openclaw",
    "linear",
    "agent",
    "webhook",
    "oauth",
    "ai-pipeline",
    "issue-triage"
  ],
  "engines": {
    "node": ">=22.16"
  },
  "files": [
    "dist/",
    "src/",
    "openclaw.plugin.json",
    "prompts.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --noEmit false --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@vitest/coverage-v8": "^4.0.18",
    "commander": "^14.0.3",
    "openclaw": "2026.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "cockatiel": "^3.2.1",
    "yaml": "^2.8.2"
  },
  "overrides": {
    "tar": "^7.5.1",
    "axios": "^1.13.10",
    "basic-ftp": "^6.0.1",
    "postcss": "^8.5.14"
  }
}
